# Environment variables for UrbanPulse backend
# Copy this file to .env and fill in your credentials

# Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Supabase service-role key (bypasses Row-Level Security — keep secret!)
SUPABASE_SERVICE_KEY=

# Express server port
PORT=3001

# Node environment
NODE_ENV=development

# ── Stage K: Sentinel Agent ────────────────────────────────────────────────
# Groq (primary LLM — free tier, no credit card): https://console.groq.com
GROQ_API_KEY=

# Google Gemini (fallback LLM — free tier): https://aistudio.google.com
GEMINI_API_KEY=

# Resend email alerts (free tier, 3000 emails/mo): https://resend.com
RESEND_API_KEY=
RESEND_FROM=
ALERT_EMAIL=

# ── Live data APIs (optional) ─────────────────────────────────────────────
# TomTom Traffic Flow API (free tier): https://developer.tomtom.com
TOMTOM_API_KEY=

# data.gov.in CPCB AQI API (free): https://data.gov.in
DATA_GOV_API_KEY=
