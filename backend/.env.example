# Environment variables for UrbanPulse backend
# Copy this file to .env and fill in your Supabase credentials

# Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key (bypasses Row-Level Security — keep secret!)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Express server port
PORT=3001

# Node environment
NODE_ENV=development
